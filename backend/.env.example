# Copy to .env and fill in. Never commit your real .env.
# Get a Gemini key from Google AI Studio: https://aistudio.google.com/apikey
# A valid Gemini key starts with "AIza...".
GEMINI_API_KEY=your_key_here
# Optional: override the model (defaults to gemini-3.1-flash-lite)
# GEMINI_MODEL=gemini-3.1-flash-lite
PORT=3001
