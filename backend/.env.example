# Copy to .env and fill in. Never commit your real .env.
# Get a Gemini key from Google AI Studio: https://aistudio.google.com/apikey
# A valid Gemini key starts with "AIza...".
GEMINI_API_KEY=your_key_here
# Optional: override the model (defaults to gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
PORT=3001
